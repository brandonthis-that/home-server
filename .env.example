# Server
PORT=8080

# Open-Meteo (forecast endpoint)
# For non-commercial usage this can stay empty if your plan does not require a key.
OPEN_METEO_API_KEY=
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# Ngong, Kenya (default forecast location)
FORECAST_LATITUDE=-1.3653
FORECAST_LONGITUDE=36.6566
